    { "lang": "en", "name": "English", "path": "lang/en.json" },
    { "lang": "ko", "name": "한국어", "path": "lang/ko.json" }
  ],
  "url": "https://github.com/JBGeum/sch-boilerplate",
  "manifest": "https://github.com/JBGeum/sch-boilerplate/releases/latest/download/module.json",
